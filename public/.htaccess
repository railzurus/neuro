# Наш index.html всегда приоритетнее дефолтного index.php Beget
DirectoryIndex index.html

# SPA-фолбэк: все несуществующие пути отдаём index.html,
# чтобы React Router обрабатывал маршруты (/compose, /review, /listen)
# и обновление страницы по прямой ссылке не давало 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Кэширование статики (хэшированные ассеты Vite можно держать долго)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# index.html не кэшируем, чтобы новые сборки подхватывались сразу
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
